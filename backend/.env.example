# Backend Configuration
PORT=3000

# GitHub Personal Access Token (Required for data ingestion)
# Must have 'read:org' and 'repo' scopes for real data fetching.
# For this prototype, a token is still required by the utility function, but data is simulated.
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# PostgreSQL Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=oss_dashboard
DB_PASSWORD=mysecretpassword
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Startup behavior
# Disabled by default to avoid high-impact operations during service startup.
ENABLE_STARTUP_CACHE_FLUSH=false
ENABLE_STARTUP_BACKFILL=false
STARTUP_BACKFILL_DAYS=30
